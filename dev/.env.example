# KiCad Agent - API Keys Configuration
# =====================================
#
# QUICK SETUP:
#   cd ../code/kicad-agent/agent
#   cp .env.example .env
#   # Edit .env and add your API keys
#

# Anthropic API Key (for Claude support - REQUIRED)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# OpenAI API Key (optional - for GPT-4 support)
OPENAI_API_KEY=your-openai-api-key-here
