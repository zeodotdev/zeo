#!/bin/bash
# zeo - CLI tool for Zeo
#
# Must clear PYTHONHOME/PYTHONPATH set by the Zeo app bundle to avoid
# conflicts between the bundled Python framework and system Python.

unset PYTHONHOME
unset PYTHONPATH

# Create temp file for Python script, keeping stdin available for interactive use
_ZEO_SCRIPT=$(mktemp)
trap "rm -f '$_ZEO_SCRIPT'" EXIT

cat > "$_ZEO_SCRIPT" <<'PYTHON_EOF'
import argparse
import json
import os
import sys
import time


LOG_DIR = os.path.expanduser("~/Library/Logs/Zeo")
MONITOR_LOG = os.path.join(LOG_DIR, "agent-monitor.jsonl")

# Zeo version - read from cmake/ZeoVersion.cmake as single source of truth
ZEO_VERSION = "0.1.0"  # Fallback if cmake file not found

def _get_zeo_version():
    """Get Zeo version from cmake/ZeoVersion.cmake."""
    # Find the cmake file relative to this script
    script_dir = os.path.dirname(os.path.abspath(__file__))
    cmake_file = os.path.join(script_dir, "..", "cmake", "ZeoVersion.cmake")

    if os.path.exists(cmake_file):
        try:
            with open(cmake_file, "r") as f:
                for line in f:
                    if "ZEO_SEMANTIC_VERSION" in line and "set(" in line:
                        # Parse: set( ZEO_SEMANTIC_VERSION "0.1.0" )
                        import re
                        match = re.search(r'"([^"]+)"', line)
                        if match:
                            return match.group(1)
        except Exception:
            pass

    return ZEO_VERSION


def cmd_tool(args):
    """TUI for executing agent tool calls."""
    import traceback

    # ANSI colors
    CYAN = "\033[36m"
    GREEN = "\033[32m"
    YELLOW = "\033[33m"
    RED = "\033[31m"
    DIM = "\033[2m"
    BOLD = "\033[1m"
    RESET = "\033[0m"

    def clear_screen():
        print("\033[2J\033[H", end="")

    def print_header(sch_status, board_status):
        print(f"{BOLD}╔══════════════════════════════════════════════════════════════╗{RESET}")
        print(f"{BOLD}║  Zeo Tool Runner                                        [?]  ║{RESET}")
        print(f"{BOLD}╠══════════════════════════════════════════════════════════════╣{RESET}")
        print(f"{BOLD}║{RESET}  Schematic: {sch_status:<12}  PCB: {board_status:<12}              {BOLD}║{RESET}")
        print(f"{BOLD}╚══════════════════════════════════════════════════════════════╝{RESET}")

    def print_menu():
        print(f"\n{DIM}Commands:{RESET}")
        print(f"  {CYAN}[p]{RESET}aste  - Paste tool call JSON (end with blank line)")
        print(f"  {CYAN}[r]{RESET}un    - Execute the current buffer")
        print(f"  {CYAN}[c]{RESET}lear  - Clear the buffer")
        print(f"  {CYAN}[?]{RESET}      - List available tools")
        print(f"  {CYAN}[q]{RESET}uit   - Exit")

    def print_buffer(buffer_lines):
        print(f"\n{BOLD}─── Tool Call Buffer ───{RESET}")
        if buffer_lines:
            for i, line in enumerate(buffer_lines[:20]):  # Show first 20 lines
                print(f"{DIM}{i+1:3}│{RESET} {line}")
            if len(buffer_lines) > 20:
                print(f"{DIM}... ({len(buffer_lines) - 20} more lines){RESET}")
        else:
            print(f"{DIM}(empty - use 'p' to paste){RESET}")
        print(f"{BOLD}────────────────────────{RESET}")

    def print_tools():
        """Print available agent tools."""
        tools = [
            ("sch_get_summary", "Get high-level overview of schematic"),
            ("sch_inspect", "Inspect specific section (symbols, wires, etc.)"),
            ("sch_add", "Add elements to schematic"),
            ("sch_update", "Update schematic elements"),
            ("sch_delete", "Delete schematic elements"),
            ("sch_switch_sheet", "Switch to a different sheet"),
            ("sch_add_sheet", "Add a new hierarchical sheet"),
            ("sch_connect_net", "Auto-route wires between pins"),
            ("sch_run_erc", "Run electrical rules check"),
            ("sch_setup", "Get/set schematic settings"),
            ("pcb_get_summary", "Get high-level overview of PCB"),
            ("pcb_inspect", "Inspect specific section of PCB"),
            ("pcb_add", "Add elements to PCB"),
            ("pcb_update", "Update PCB elements"),
            ("pcb_delete", "Delete PCB elements"),
            ("run_terminal", "Execute bash/shell commands"),
            ("check_status", "Get project and editor status"),
        ]

        print(f"\n{BOLD}─── Available Tools ───{RESET}")
        for name, desc in tools:
            print(f"  {CYAN}{name:<22}{RESET} {desc}")
        print(f"{BOLD}───────────────────────{RESET}")
        print(f"\n{DIM}Tool call format:{RESET}")
        print(f'  {{"name": "tool_name", "input": {{...}}}}')

    def execute_tool(buffer_lines, namespace):
        """Execute the tool call in the buffer."""
        if not buffer_lines:
            print(f"{YELLOW}Buffer is empty. Use 'p' to paste a tool call.{RESET}")
            return

        buffer_text = "\n".join(buffer_lines)

        # Try to parse as JSON tool call
        try:
            tool_call = json.loads(buffer_text)
            if isinstance(tool_call, dict) and "name" in tool_call:
                # It's a tool call JSON - generate Python code
                tool_name = tool_call.get("name", "")
                tool_input = tool_call.get("input", {})

                print(f"\n{CYAN}Executing tool: {tool_name}{RESET}")
                print(f"{DIM}Input: {json.dumps(tool_input, indent=2)}{RESET}")

                # For now, we can't directly execute tool calls without the C++ handler
                # So we'll show what the user would need to do in Python
                print(f"\n{YELLOW}Note: Direct tool execution not yet implemented.{RESET}")
                print(f"{DIM}Use 'zeo shell' to run Python code directly, e.g.:{RESET}")
                if tool_name.startswith("sch_"):
                    print(f"  sch.get_symbols()  # for sch_inspect")
                elif tool_name.startswith("pcb_"):
                    print(f"  board.get_footprints()  # for pcb_inspect")
                return
        except json.JSONDecodeError:
            pass

        # Execute as Python code
        print(f"\n{CYAN}Executing Python code...{RESET}")
        try:
            # Try as expression first
            result = eval(buffer_text, namespace)
            if result is not None:
                print(f"\n{GREEN}Result:{RESET}")
                try:
                    print(json.dumps(result, indent=2, default=str))
                except (TypeError, ValueError):
                    print(result)
        except SyntaxError:
            # Execute as statements
            exec(buffer_text, namespace)
            print(f"{GREEN}Executed successfully.{RESET}")

    # Try to import kipy
    try:
        from kipy import KiCad
    except ImportError as e:
        print(f"Error: Could not import kipy: {e}")
        print("\nMake sure kipy is installed with:")
        print("  pip install -e /path/to/zeo-python")
        sys.exit(1)

    # Connect to Zeo
    zeo_version = _get_zeo_version()
    print(f"Connecting to Zeo {zeo_version}...")
    try:
        kicad = KiCad()
        kicad_version = kicad.get_version()
        print(f"Connected (KiCad {kicad_version})")
    except Exception as e:
        print(f"Error: Could not connect to Zeo: {e}")
        print("Make sure Zeo is running with a project open.")
        sys.exit(1)

    # Get schematic and board
    sch = None
    board = None
    sch_status = f"{RED}not open{RESET}"
    board_status = f"{RED}not open{RESET}"

    try:
        sch = kicad.get_schematic()
        sch_status = f"{GREEN}connected{RESET}"
    except Exception:
        pass

    try:
        board = kicad.get_board()
        board_status = f"{GREEN}connected{RESET}"
    except Exception:
        pass

    # Set up namespace for exec
    namespace = {
        'kicad': kicad,
        'sch': sch,
        'board': board,
        'json': json,
    }

    buffer_lines = []

    # Main loop
    clear_screen()
    while True:
        try:
            print_header(sch_status, board_status)
            print_buffer(buffer_lines)
            print_menu()

            cmd = input(f"\n{BOLD}>{RESET} ").strip().lower()

            if cmd in ('q', 'quit', 'exit'):
                break
            elif cmd in ('?', 'tools', 'help'):
                clear_screen()
                print_tools()
                input(f"\n{DIM}Press Enter to continue...{RESET}")
                clear_screen()
            elif cmd in ('p', 'paste'):
                clear_screen()
                print(f"{CYAN}Paste your tool call JSON or Python code.{RESET}")
                print(f"{DIM}End with a blank line.{RESET}\n")
                buffer_lines = []
                while True:
                    try:
                        line = input()
                        if line == "":
                            break
                        buffer_lines.append(line)
                    except EOFError:
                        break
                clear_screen()
                if buffer_lines:
                    print(f"{GREEN}Pasted {len(buffer_lines)} lines.{RESET}\n")
            elif cmd in ('r', 'run'):
                try:
                    execute_tool(buffer_lines, namespace)
                except Exception as e:
                    print(f"{RED}Error:{RESET} {e}")
                    if args.verbose:
                        traceback.print_exc()
                input(f"\n{DIM}Press Enter to continue...{RESET}")
                clear_screen()
            elif cmd in ('c', 'clear'):
                buffer_lines = []
                clear_screen()
                print(f"{GREEN}Buffer cleared.{RESET}\n")
            else:
                clear_screen()
                print(f"{YELLOW}Unknown command: {cmd}{RESET}\n")

        except KeyboardInterrupt:
            print(f"\n{DIM}(Use 'q' to quit){RESET}")
            continue

    print(f"\n{DIM}Goodbye!{RESET}")


def cmd_shell(args):
    """Open an interactive Python shell with kipy imported."""
    import code
    import readline  # noqa: F401 - enables arrow keys, history
    import rlcompleter  # noqa: F401 - enables tab completion

    # Try to import kipy
    try:
        from kipy import KiCad
    except ImportError as e:
        print(f"Error: Could not import kipy: {e}")
        print("\nMake sure kipy is installed. You can install it with:")
        print("  pip install -e /path/to/zeo-python")
        sys.exit(1)

    # Connect to Zeo
    zeo_version = _get_zeo_version()
    print(f"Connecting to Zeo {zeo_version}...")
    try:
        kicad = KiCad()
        kicad_version = kicad.get_version()
        print(f"Connected (KiCad {kicad_version})")
    except Exception as e:
        print(f"Warning: Could not connect to Zeo: {e}")
        print("You can try connecting manually with: kicad = KiCad()")
        kicad = None

    # Set up the namespace with useful imports and objects
    namespace = {
        'KiCad': KiCad,
        'kicad': kicad,
    }

    # Try to get schematic and board if connected
    sch = None
    board = None
    if kicad:
        try:
            sch = kicad.get_schematic()
            namespace['sch'] = sch
            print("Schematic available as 'sch'")
        except Exception:
            pass

        try:
            board = kicad.get_board()
            namespace['board'] = board
            print("Board available as 'board'")
        except Exception:
            pass

        if not sch and not board:
            print("\n\033[33mWarning: No editors connected. Open the schematic or PCB editor in Zeo first.\033[0m")

    # Enable tab completion
    readline.set_completer(rlcompleter.Completer(namespace).complete)
    readline.parse_and_bind("tab: complete")

    # Print help
    print("\n" + "=" * 50)
    print("Zeo Shell - Interactive Python with kipy")
    print("=" * 50)
    print("\nAvailable objects:")
    print("  kicad   - KiCad connection")
    if sch:
        print("  sch     - Current schematic")
    if board:
        print("  board   - Current board")
    print("\nExample commands:")
    print("  kicad.ping()")
    print("  sch.get_symbols()")
    print("  board.get_footprints()")
    print("\nType 'exit()' or Ctrl-D to quit.")
    print()

    # Start interactive shell
    code.interact(local=namespace, banner="", exitmsg="")


def cmd_monitor(args):
    """Watch agent shell calls and responses."""
    if not os.path.exists(MONITOR_LOG):
        print(f"No monitor log found at {MONITOR_LOG}")
        print("Agent commands will appear here once the agent starts running.")
        if args.follow:
            print("Waiting for log file...")
            while not os.path.exists(MONITOR_LOG):
                time.sleep(0.5)
        else:
            return

    if args.follow:
        _tail_follow(args)
    else:
        _show_recent(args)


def _show_recent(args, count=50):
    """Show the last N events from the log."""
    lines = []
    try:
        with open(MONITOR_LOG, "r") as f:
            for line in f:
                line = line.strip()
                if line:
                    lines.append(line)
    except FileNotFoundError:
        print("No monitor log found.")
        return

    recent = lines[-count:]

    if not recent:
        print("No events recorded yet.")
        return

    for line in recent:
        _format_line(line, args.json)


def _tail_follow(args):
    """Stream events in real-time (tail -f style)."""
    try:
        with open(MONITOR_LOG, "r") as f:
            # Seek to end
            f.seek(0, 2)

            while True:
                line = f.readline()
                if line:
                    line = line.strip()
                    if line:
                        _format_line(line, args.json)
                else:
                    time.sleep(0.1)
    except KeyboardInterrupt:
        pass


def _format_line(line, raw_json=False):
    """Format a JSONL line for display."""
    if raw_json:
        print(line)
        return

    try:
        data = json.loads(line)
    except json.JSONDecodeError:
        print(line)
        return

    ts = data.get("ts", "")
    # Show just time portion (HH:MM:SS.mmm)
    time_str = ts.split("T")[1] if "T" in ts else ts

    event = data.get("event", "")

    if event == "cmd_start":
        cmd_type = data.get("type", "")
        mode = data.get("mode", "")
        cmd = data.get("cmd", "")

        # Truncate long commands for display
        if len(cmd) > 200:
            cmd = cmd[:200] + "..."

        mode_str = f"  {mode:<5}" if mode else "      "
        print(f"\033[36m{time_str}\033[0m{mode_str} \033[33m{cmd_type}\033[0m")
        # Show the command indented
        for cmd_line in cmd.split("\\n"):
            if cmd_line.strip():
                print(f"  {cmd_line}")

    elif event == "cmd_end":
        success = data.get("success", False)
        duration = data.get("duration_ms", 0)
        output = data.get("output", "")

        if success:
            status = f"\033[32mOK\033[0m ({duration}ms)"
        else:
            status = f"\033[31mFAIL\033[0m ({duration}ms)"

        # Truncate long output for display
        if len(output) > 500:
            output = output[:500] + "..."

        print(f"  {status}")
        if output and output != "(no output)":
            # Show first few lines of output
            out_lines = output.split("\\n")
            for out_line in out_lines[:10]:
                if out_line.strip():
                    print(f"  \033[2m{out_line}\033[0m")
            if len(out_lines) > 10:
                print(f"  \033[2m... ({len(out_lines) - 10} more lines)\033[0m")
        print()

    elif event == "error":
        context = data.get("context", "")
        error = data.get("error", "")
        print(f"\033[36m{time_str}\033[0m  \033[31mERROR\033[0m [{context}] {error}")
        print()

    else:
        # Unknown event type, show raw
        print(line)


def main():
    zeo_version = _get_zeo_version()

    parser = argparse.ArgumentParser(
        prog="zeo",
        description="CLI tool for Zeo",
    )
    parser.add_argument(
        "-V", "--version",
        action="version",
        version=f"Zeo {zeo_version}",
    )
    subparsers = parser.add_subparsers(dest="command", help="Available commands")

    # shell subcommand
    subparsers.add_parser(
        "shell",
        help="Open an interactive Python shell with kipy imported",
    )

    # tool subcommand
    tool_parser = subparsers.add_parser(
        "tool",
        help="Execute agent tool calls (paste Python code from monitor logs)",
    )
    tool_parser.add_argument(
        "-v", "--verbose",
        action="store_true",
        help="Show full stack traces on errors",
    )

    # monitor subcommand
    monitor_parser = subparsers.add_parser(
        "monitor",
        help="Watch agent shell calls and responses",
    )
    monitor_parser.add_argument(
        "-f", "--follow",
        action="store_true",
        help="Stream events in real-time (tail -f style)",
    )
    monitor_parser.add_argument(
        "--json",
        action="store_true",
        help="Output raw JSON lines",
    )

    args = parser.parse_args()

    if args.command is None:
        parser.print_help()
        sys.exit(1)

    if args.command == "shell":
        cmd_shell(args)
    elif args.command == "tool":
        cmd_tool(args)
    elif args.command == "monitor":
        cmd_monitor(args)
    else:
        parser.print_help()
        sys.exit(1)


if __name__ == "__main__":
    main()
PYTHON_EOF

exec /usr/bin/env python3 "$_ZEO_SCRIPT" "$@"
