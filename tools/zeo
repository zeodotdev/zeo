#!/bin/bash
# zeo - CLI tool for Zeo
#
# This script detects whether it's running from a macOS app bundle and uses
# the bundled Python framework if available. Otherwise falls back to system Python.
#
# App bundle structure:
#   Zeo.app/Contents/SharedSupport/bin/zeo       <- this script
#   Zeo.app/Contents/Frameworks/Python.framework/Versions/Current/bin/python3

# Resolve the real path of this script (follows symlinks)
# This ensures the manifest can be found even when run via a symlink
_zeo_script="$0"
while [ -L "$_zeo_script" ]; do
    _zeo_dir="$(cd "$(dirname "$_zeo_script")" && pwd)"
    _zeo_script="$(readlink "$_zeo_script")"
    # Handle relative symlinks
    [[ "$_zeo_script" != /* ]] && _zeo_script="$_zeo_dir/$_zeo_script"
done
export ZEO_SCRIPT_DIR="$(cd "$(dirname "$_zeo_script")" && pwd)"

# Determine which Python to use
_ZEO_PYTHON=""

# Check if we're in a macOS app bundle (SharedSupport/bin/zeo -> Contents/SharedSupport/bin)
if [[ "$ZEO_SCRIPT_DIR" == *"/Contents/SharedSupport/bin" ]]; then
    # We're in an app bundle - use the bundled Python framework
    _APP_CONTENTS="${ZEO_SCRIPT_DIR%/SharedSupport/bin}"
    _BUNDLED_PYTHON="$_APP_CONTENTS/Frameworks/Python.framework/Versions/Current/bin/python3"

    if [ -x "$_BUNDLED_PYTHON" ]; then
        _ZEO_PYTHON="$_BUNDLED_PYTHON"
        # Set PYTHONHOME to the framework so it finds its standard library
        export PYTHONHOME="$_APP_CONTENTS/Frameworks/Python.framework/Versions/Current"
        # Clear any conflicting PYTHONPATH from the environment
        unset PYTHONPATH
    fi
fi

# Check if we're in a Linux AppImage
if [ -n "$APPDIR" ]; then
    # Inside AppImage - keep PYTHONHOME/PYTHONPATH so bundled Python finds kipy
    _ZEO_PYTHON="${APPDIR}/usr/bin/python3"
fi

# Fall back to system Python if no bundled Python found
if [ -z "$_ZEO_PYTHON" ]; then
    # Clear any lingering Python environment from app bundle
    unset PYTHONHOME
    unset PYTHONPATH
    _ZEO_PYTHON="/usr/bin/env python3"
fi

# Create temp file for Python script, keeping stdin available for interactive use
_ZEO_SCRIPT=$(mktemp)
trap "rm -f '$_ZEO_SCRIPT'" EXIT

cat > "$_ZEO_SCRIPT" <<'PYTHON_EOF'
import argparse
import json
import os
import sys
import time


LOG_DIR = os.path.expanduser("~/Library/Logs/Zeo")
MONITOR_LOG = os.path.join(LOG_DIR, "agent-monitor.jsonl")

# Zeo version - read from cmake/ZeoVersion.cmake as single source of truth
ZEO_VERSION = "0.1.1"  # Fallback if cmake file not found

def _get_zeo_version():
    """Get Zeo version from cmake/ZeoVersion.cmake."""
    # Find the cmake file relative to this script
    script_dir = os.path.dirname(os.path.abspath(__file__))
    cmake_file = os.path.join(script_dir, "..", "cmake", "ZeoVersion.cmake")

    if os.path.exists(cmake_file):
        try:
            with open(cmake_file, "r") as f:
                for line in f:
                    if "ZEO_SEMANTIC_VERSION" in line and "set(" in line:
                        # Parse: set( ZEO_SEMANTIC_VERSION "0.1.0" )
                        import re
                        match = re.search(r'"([^"]+)"', line)
                        if match:
                            return match.group(1)
        except Exception:
            pass

    return ZEO_VERSION


def cmd_tool(args):
    """TUI for manually running agent tool calls."""
    # Check for textual library
    try:
        from textual.app import App, ComposeResult
        from textual.containers import Horizontal, Vertical, VerticalScroll
        from textual.widgets import Static, ListView, ListItem, Footer, TextArea, Button, Select, Input
        from textual.reactive import reactive
        from textual.binding import Binding
        from textual import work
        import subprocess
        from datetime import datetime
    except ImportError:
        print("Error: textual library required for TUI mode.")
        print("Install with: pip install textual")
        sys.exit(1)

    def copy_to_clipboard(text: str) -> bool:
        """Copy text to system clipboard."""
        try:
            proc = subprocess.Popen(['pbcopy'], stdin=subprocess.PIPE)
            proc.communicate(text.encode('utf-8'))
            return proc.returncode == 0
        except FileNotFoundError:
            try:
                proc = subprocess.Popen(['xclip', '-selection', 'clipboard'], stdin=subprocess.PIPE)
                proc.communicate(text.encode('utf-8'))
                return proc.returncode == 0
            except FileNotFoundError:
                return False

    def _load_tools_from_manifest():
        """Load all tools from tool_manifest.json."""
        # Use ZEO_SCRIPT_DIR env var set by bash wrapper (since script runs from temp file)
        script_dir = os.environ.get("ZEO_SCRIPT_DIR", os.path.dirname(os.path.abspath(__file__)))

        # Check both possible paths (source tree vs packaged app)
        candidate_paths = [
            os.path.join(script_dir, "..", "agent", "tools", "python", "tool_manifest.json"),  # Source tree
            os.path.join(script_dir, "..", "agent", "python", "tool_manifest.json"),  # Packaged app
        ]

        manifest_path = None
        for path in candidate_paths:
            normalized = os.path.normpath(path)
            if os.path.exists(normalized):
                manifest_path = normalized
                break

        if manifest_path is None:
            print(f"Warning: tool_manifest.json not found in expected locations", file=sys.stderr)
            manifest_path = os.path.normpath(candidate_paths[0])  # Fallback for error message

        tools = []
        if os.path.exists(manifest_path):
            try:
                with open(manifest_path, "r") as f:
                    manifest = json.load(f)
                for entry in manifest:
                    name = entry.get("name", "")
                    if not name:
                        continue
                    desc = entry.get("description", "")[:60]  # Truncate for display
                    # Build example input from input_schema
                    example = {}
                    schema = entry.get("input_schema", {})
                    props = schema.get("properties", {})
                    required = schema.get("required", [])
                    for prop_name, prop_def in props.items():
                        if prop_name in required:
                            prop_type = prop_def.get("type", "string")
                            if prop_type == "string":
                                example[prop_name] = ""
                            elif prop_type == "integer" or prop_type == "number":
                                example[prop_name] = 0
                            elif prop_type == "boolean":
                                example[prop_name] = False
                            elif prop_type == "array":
                                example[prop_name] = []
                            elif prop_type == "object":
                                example[prop_name] = {}
                    tools.append((name, desc, example))
            except Exception as e:
                print(f"Warning: Could not load tool manifest: {e}", file=sys.stderr)

        # Fallback if manifest not found or empty
        if not tools:
            tools = [
                ("sch_get_summary", "Get schematic overview", {}),
                ("sch_inspect", "Inspect schematic elements", {"section": "symbols"}),
                ("pcb_get_summary", "Get PCB overview", {}),
                ("check_status", "Get project status", {}),
            ]
        return tools

    AVAILABLE_TOOLS = _load_tools_from_manifest()

    # =========================================================================
    # Tool Call data structure
    # =========================================================================
    class ToolCall:
        """Represents a manually-run tool call."""
        def __init__(self, tool_name, input_json, timestamp=None):
            self.tool_id = f"manual_{int(time.time() * 1000)}"
            self.tool_name = tool_name
            self.description = tool_name
            self.input_json = input_json
            self.timestamp = timestamp or datetime.now().isoformat()
            self.success = None
            self.duration_ms = 0
            self.result = ""

        def time_str(self):
            if "T" in self.timestamp:
                return self.timestamp.split("T")[1].split(".")[0]
            return self.timestamp[:8]

        def status_str(self):
            if self.success is None:
                return "[yellow]RUN[/yellow]"
            elif self.success:
                return "[green]OK[/green]"
            else:
                return "[red]FAIL[/red]"

        def get_input_text(self):
            try:
                if isinstance(self.input_json, str):
                    input_obj = json.loads(self.input_json)
                else:
                    input_obj = self.input_json
                return json.dumps(input_obj, indent=2)
            except (json.JSONDecodeError, TypeError):
                return str(self.input_json)

        def get_output_text(self):
            if not self.result:
                return ""
            try:
                result_obj = json.loads(self.result)
                return json.dumps(result_obj, indent=2)
            except (json.JSONDecodeError, TypeError):
                return self.result

    # =========================================================================
    # Custom widgets
    # =========================================================================
    class ToolListItem(ListItem):
        def __init__(self, tool_call: ToolCall, index: int):
            super().__init__()
            self.tool_call = tool_call
            self.index = index

        def compose(self) -> ComposeResult:
            tc = self.tool_call
            yield Static(
                f"{tc.time_str()} {tc.status_str()}\n [dim]{tc.tool_name}[/dim]",
                markup=True
            )

    class DetailView(Static):
        def __init__(self):
            super().__init__("")
            self._tool_call = None

        def set_tool_call(self, tc: ToolCall):
            self._tool_call = tc
            self._update_content()

        def _update_content(self):
            if self._tool_call is None:
                self.update("[dim]Select a tool, edit input, and click Run[/dim]")
                return

            tc = self._tool_call
            result_formatted = tc.get_output_text()
            if result_formatted and len(result_formatted) > 5000:
                result_formatted = result_formatted[:5000] + "\n... (truncated)"

            if tc.success is None:
                status_line = "[yellow]Running...[/yellow]"
            elif tc.success:
                status_line = f"[green]Success[/green] ({tc.duration_ms}ms)"
            else:
                status_line = f"[red]Failed[/red] ({tc.duration_ms}ms)"

            # Escape result to prevent Rich markup interpretation of brackets in JSON
            # Use backslash escape: [ -> \[
            if result_formatted:
                escaped_result = result_formatted.replace('[', '\\[')
            else:
                escaped_result = '[dim](no output yet)[/dim]'

            content = f"""[bold]{tc.tool_name}[/bold] - {status_line}

{escaped_result}"""

            self.update(content)

    # =========================================================================
    # Main TUI App
    # =========================================================================
    class ToolApp(App):
        """TUI for manually running agent tool calls."""

        CSS = """
        Horizontal {
            height: 1fr;
        }
        #sidebar {
            width: 35;
            height: 100%;
            border-right: solid $primary;
        }
        #sidebar-title {
            height: 1;
            background: $primary;
            color: $text;
            text-align: center;
        }
        #main-panel {
            height: 100%;
        }
        #detail-title {
            height: 1;
            background: $primary;
            color: $text;
            text-align: center;
        }
        #tool-search {
            height: 3;
            margin: 1 1 0 1;
        }
        #tool-selector {
            height: 3;
            margin: 0 1 1 1;
        }
        #input-label {
            height: 1;
            margin: 0 1;
        }
        #input-area {
            height: 8;
            margin: 0 1;
            border: solid $primary;
        }
        #run-button {
            margin: 1;
            width: 100%;
        }
        #output-label {
            height: 1;
            margin: 0 1;
            background: $surface;
        }
        #output-scroll {
            height: 1fr;
            padding: 0 1;
        }
        ListView {
            height: 1fr;
        }
        ListItem {
            padding: 0 1;
        }
        ListItem:hover {
            background: $primary 30%;
        }
        ListView:focus ListItem.--highlight {
            background: $primary 50%;
        }
        #connection-status {
            height: 1;
            background: $error;
            color: $text;
            text-align: center;
        }
        #connection-status.connected {
            background: $success;
        }
        """

        BINDINGS = [
            Binding("q", "quit", "Quit"),
            Binding("ctrl+r", "run_tool", "Run"),
            Binding("/", "focus_search", "Search"),
            Binding("i", "copy_input", "Copy Input"),
            Binding("o", "copy_output", "Copy Output"),
            Binding("up", "cursor_up", "Up", show=False),
            Binding("down", "cursor_down", "Down", show=False),
        ]

        def __init__(self):
            super().__init__()
            self.tool_calls: list[ToolCall] = []
            self._current_tool_call: ToolCall = None
            self._kicad = None
            self._connected = False
            self._shutting_down = False

        def compose(self) -> ComposeResult:
            with Horizontal():
                with Vertical(id="sidebar"):
                    yield Static("History", id="sidebar-title")
                    yield ListView(id="tool-list")
                with Vertical(id="main-panel"):
                    yield Static("Tool Runner", id="detail-title")
                    yield Static("Connecting...", id="connection-status")
                    yield Input(placeholder="Search tools...", id="tool-search")
                    yield Select(
                        [(f"{name} - {desc}", name) for name, desc, _ in AVAILABLE_TOOLS],
                        prompt="Select a tool",
                        id="tool-selector"
                    )
                    yield Static("[bold]Input JSON:[/bold]", id="input-label")
                    yield TextArea("{}", id="input-area")
                    yield Button("Run Tool (Ctrl+R)", id="run-button", variant="primary")
                    yield Static("[bold]Output:[/bold]", id="output-label")
                    with VerticalScroll(id="output-scroll"):
                        yield DetailView()
            yield Footer()

        def on_mount(self):
            self._connect_to_zeo()

        def action_focus_search(self):
            """Focus the search input."""
            search_input = self.query_one("#tool-search", Input)
            search_input.focus()

        def action_quit(self):
            """Clean up and quit."""
            self._shutting_down = True

            # Cancel all background workers
            self.workers.cancel_all()

            # Close the pynng connection explicitly
            if self._kicad is not None:
                try:
                    if hasattr(self._kicad, '_client') and hasattr(self._kicad._client, '_conn'):
                        self._kicad._client._conn.close()
                except Exception:
                    pass
            self._kicad = None

            self.exit()

        @work(thread=True, exit_on_error=False)
        def _connect_to_zeo(self):
            """Connect to Zeo in background."""
            if self._shutting_down:
                return
            try:
                from kipy import KiCad
                # Use a shorter timeout to allow faster shutdown
                self._kicad = KiCad(timeout_ms=2000)
                if self._shutting_down:
                    return
                version = self._kicad.get_version()
                self._connected = True
                if not self._shutting_down:
                    self.call_from_thread(self._update_connection_status, True, version)
            except Exception as e:
                self._connected = False
                if not self._shutting_down:
                    self.call_from_thread(self._update_connection_status, False, str(e))

        def _update_connection_status(self, connected: bool, info: str):
            status = self.query_one("#connection-status", Static)
            if connected:
                status.update(f"Connected: {info}")
                status.add_class("connected")
            else:
                status.update(f"Not connected - {info}")
                status.remove_class("connected")

        def on_input_changed(self, event: Input.Changed):
            """Filter tool dropdown based on search input."""
            if event.input.id != "tool-search":
                return

            search_text = event.value.lower().strip()
            selector = self.query_one("#tool-selector", Select)

            if not search_text:
                # Show all tools when search is empty
                options = [(f"{name} - {desc}", name) for name, desc, _ in AVAILABLE_TOOLS]
            else:
                # Filter tools by name or description
                options = [
                    (f"{name} - {desc}", name)
                    for name, desc, _ in AVAILABLE_TOOLS
                    if search_text in name.lower() or search_text in desc.lower()
                ]

            selector.set_options(options)

        def on_select_changed(self, event: Select.Changed):
            """When tool is selected, populate input with example."""
            if event.value and event.value != Select.BLANK:
                for name, desc, example in AVAILABLE_TOOLS:
                    if name == event.value:
                        input_area = self.query_one("#input-area", TextArea)
                        input_area.text = json.dumps(example, indent=2)
                        break

        def on_button_pressed(self, event: Button.Pressed):
            if event.button.id == "run-button":
                self.action_run_tool()

        def action_run_tool(self):
            """Run the selected tool with the given input."""
            if not self._connected:
                self.notify("Not connected to Zeo", severity="error")
                return

            selector = self.query_one("#tool-selector", Select)
            input_area = self.query_one("#input-area", TextArea)

            if selector.value == Select.BLANK:
                self.notify("Please select a tool first", severity="warning")
                return

            tool_name = selector.value

            # Parse input JSON
            try:
                input_json = json.loads(input_area.text)
            except json.JSONDecodeError as e:
                self.notify(f"Invalid JSON: {e}", severity="error")
                return

            # Create tool call record
            tc = ToolCall(tool_name, input_json)
            self.tool_calls.insert(0, tc)
            self._current_tool_call = tc
            self._refresh_list()

            # Run the tool in background
            self._execute_tool(tc)

        @work(thread=True, exit_on_error=False)
        def _execute_tool(self, tc: ToolCall):
            """Execute a tool call in background using kicad.execute_tool()."""
            if self._shutting_down:
                return

            import time as time_module
            start_time = time_module.time()

            try:
                if self._shutting_down or self._kicad is None:
                    return

                tool_name = tc.tool_name
                input_json = tc.input_json

                if self._shutting_down:
                    return

                # Use the generic execute_tool API that routes to C++ tool handlers
                result = self._kicad.execute_tool(
                    tool_name=tool_name,
                    tool_args_json=json.dumps(input_json),
                )

                if result.get("success"):
                    output = result.get("result_json", "").strip()
                    if output and output != "(no output)":
                        # Try to parse and re-format as pretty JSON
                        try:
                            parsed = json.loads(output)
                            tc.result = json.dumps(parsed, indent=2, default=str)
                        except json.JSONDecodeError:
                            tc.result = output
                    else:
                        tc.result = json.dumps({"status": "success", "message": "Tool completed"})
                    tc.success = True
                else:
                    tc.result = json.dumps({
                        "status": "error",
                        "message": result.get("error_message", "Unknown error")
                    }, indent=2)
                    tc.success = False

            except Exception as e:
                tc.result = json.dumps({"error": str(e)}, indent=2)
                tc.success = False

            tc.duration_ms = int((time_module.time() - start_time) * 1000)

            if not self._shutting_down:
                self.call_from_thread(self._update_after_execution, tc)

        def _update_after_execution(self, tc: ToolCall):
            """Update UI after tool execution."""
            self._refresh_list()
            detail = self.query_one(DetailView)
            detail.set_tool_call(tc)
            if tc.success:
                self.notify(f"{tc.tool_name} completed in {tc.duration_ms}ms")
            else:
                self.notify(f"{tc.tool_name} failed", severity="error")

        def _refresh_list(self):
            list_view = self.query_one("#tool-list", ListView)
            list_view.clear()

            for i, tc in enumerate(self.tool_calls):
                list_view.append(ToolListItem(tc, i))

            if self.tool_calls:
                list_view.index = 0

        def on_list_view_selected(self, event: ListView.Selected):
            if event.item and isinstance(event.item, ToolListItem):
                self._select_history_item(event.item.tool_call)

        def on_list_view_highlighted(self, event: ListView.Highlighted):
            if event.item and isinstance(event.item, ToolListItem):
                self._select_history_item(event.item.tool_call)

        def _select_history_item(self, tc: ToolCall):
            """When a history item is selected, populate the editor and show output."""
            self._current_tool_call = tc

            # Update the tool selector
            selector = self.query_one("#tool-selector", Select)
            selector.value = tc.tool_name

            # Update the input area with this tool's input
            input_area = self.query_one("#input-area", TextArea)
            input_area.text = tc.get_input_text()

            # Update the output display
            detail = self.query_one(DetailView)
            detail.set_tool_call(tc)

        def action_copy_input(self):
            if self._current_tool_call:
                text = self._current_tool_call.get_input_text()
                if copy_to_clipboard(text):
                    self.notify("Input copied")
                else:
                    self.notify("Failed to copy", severity="error")
            else:
                self.notify("No tool call selected", severity="warning")

        def action_copy_output(self):
            if self._current_tool_call:
                text = self._current_tool_call.get_output_text()
                if text:
                    if copy_to_clipboard(text):
                        self.notify("Output copied")
                    else:
                        self.notify("Failed to copy", severity="error")
                else:
                    self.notify("No output available", severity="warning")
            else:
                self.notify("No tool call selected", severity="warning")

    # Run the TUI app
    app = ToolApp()
    app.run()


def cmd_shell(args):
    """Open an interactive Python shell with kipy imported."""
    import code
    import readline  # noqa: F401 - enables arrow keys, history
    import rlcompleter  # noqa: F401 - enables tab completion

    # Try to import kipy
    try:
        from kipy import KiCad
    except ImportError as e:
        print(f"Error: Could not import kipy: {e}")
        print("\nMake sure kipy is installed. You can install it with:")
        print("  pip install -e /path/to/zeo-python")
        sys.exit(1)

    # Connect to Zeo
    zeo_version = _get_zeo_version()
    print(f"Connecting to Zeo {zeo_version}...")
    try:
        kicad = KiCad()
        kicad_version = kicad.get_version()
        print(f"Connected (KiCad {kicad_version})")
    except Exception as e:
        print(f"Warning: Could not connect to Zeo: {e}")
        print("You can try connecting manually with: kicad = KiCad()")
        kicad = None

    # Set up the namespace with useful imports and objects
    namespace = {
        'KiCad': KiCad,
        'kicad': kicad,
    }

    # Try to get schematic and board if connected
    sch = None
    board = None
    if kicad:
        try:
            sch = kicad.get_schematic()
            namespace['sch'] = sch
            print("Schematic available as 'sch'")
        except Exception:
            pass

        try:
            board = kicad.get_board()
            namespace['board'] = board
            print("Board available as 'board'")
        except Exception:
            pass

        if not sch and not board:
            print("\n\033[33mWarning: No editors connected. Open the schematic or PCB editor in Zeo first.\033[0m")

    # Enable tab completion
    readline.set_completer(rlcompleter.Completer(namespace).complete)
    readline.parse_and_bind("tab: complete")

    # Print help
    print("\n" + "=" * 50)
    print("Zeo Shell - Interactive Python with kipy")
    print("=" * 50)
    print("\nAvailable objects:")
    print("  kicad   - KiCad connection")
    if sch:
        print("  sch     - Current schematic")
    if board:
        print("  board   - Current board")
    print("\nExample commands:")
    print("  kicad.ping()")
    print("  sch.get_symbols()")
    print("  board.get_footprints()")
    print("\nType 'exit()' or Ctrl-D to quit.")
    print()

    # Start interactive shell
    code.interact(local=namespace, banner="", exitmsg="")


def cmd_mcp(args):
    """Run MCP server for Claude Code integration."""
    try:
        from kipy.mcp.server import run
    except ImportError as e:
        print(f"Error: Could not import kipy.mcp: {e}")
        print("\nMake sure kipy is installed with MCP extras:")
        print('  pip install -e "/path/to/zeo-python[mcp]"')
        sys.exit(1)

    import asyncio
    asyncio.run(run())


def cmd_monitor(args):
    """Watch agent tool calls and responses with TUI."""
    # Raw JSON mode - use simple output
    if args.json:
        _monitor_raw_json(args)
        return

    # Check for textual library
    try:
        from textual.app import App, ComposeResult
        from textual.containers import Horizontal, Vertical, VerticalScroll
        from textual.widgets import Static, ListView, ListItem, Footer
        from textual.reactive import reactive
        from textual.binding import Binding
        from textual import work
        import subprocess
    except ImportError:
        print("Error: textual library required for TUI mode.")
        print("Install with: pip install textual")
        print("\nFalling back to raw JSON mode...")
        args.json = True
        _monitor_raw_json(args)
        return

    def copy_to_clipboard(text: str) -> bool:
        """Copy text to system clipboard."""
        try:
            # macOS
            proc = subprocess.Popen(['pbcopy'], stdin=subprocess.PIPE)
            proc.communicate(text.encode('utf-8'))
            return proc.returncode == 0
        except FileNotFoundError:
            try:
                # Linux with xclip
                proc = subprocess.Popen(['xclip', '-selection', 'clipboard'], stdin=subprocess.PIPE)
                proc.communicate(text.encode('utf-8'))
                return proc.returncode == 0
            except FileNotFoundError:
                return False

    # =========================================================================
    # Tool Call data structure
    # =========================================================================
    class ToolCall:
        """Represents a tool call with start/end data."""
        def __init__(self, tool_id, tool_name, description, input_json, timestamp):
            self.tool_id = tool_id
            self.tool_name = tool_name
            self.description = description
            self.input_json = input_json
            self.timestamp = timestamp
            self.success = None  # None = running, True = success, False = failed
            self.duration_ms = 0
            self.result = ""

        def time_str(self):
            """Get HH:MM:SS from timestamp."""
            if "T" in self.timestamp:
                return self.timestamp.split("T")[1].split(".")[0]
            return self.timestamp[:8]

        def status_str(self):
            """Get status string for display."""
            if self.success is None:
                return "[yellow]RUN[/yellow]"
            elif self.success:
                return "[green]OK[/green]"
            else:
                return "[red]FAIL[/red]"

        def get_input_text(self):
            """Get formatted input JSON for copying."""
            try:
                if isinstance(self.input_json, str):
                    input_obj = json.loads(self.input_json)
                else:
                    input_obj = self.input_json
                return json.dumps(input_obj, indent=2)
            except (json.JSONDecodeError, TypeError):
                return str(self.input_json)

        def get_output_text(self):
            """Get formatted output for copying."""
            if not self.result:
                return ""
            try:
                result_obj = json.loads(self.result)
                return json.dumps(result_obj, indent=2)
            except (json.JSONDecodeError, TypeError):
                return self.result

    # =========================================================================
    # Custom widgets
    # =========================================================================
    class ToolListItem(ListItem):
        """A single tool call in the sidebar list."""
        def __init__(self, tool_call: ToolCall, index: int):
            super().__init__()
            self.tool_call = tool_call
            self.index = index

        def compose(self) -> ComposeResult:
            tc = self.tool_call
            # Truncate description for sidebar
            desc = tc.description[:35] + "..." if len(tc.description) > 38 else tc.description
            yield Static(
                f"{tc.time_str()} {tc.status_str()}\n [dim]{desc}[/dim]",
                markup=True
            )

    class DetailView(Static):
        """Right panel showing selected tool call details."""
        def __init__(self):
            super().__init__("")
            self._tool_call = None

        def set_tool_call(self, tc: ToolCall):
            self._tool_call = tc
            self._update_content()

        def _update_content(self):
            if self._tool_call is None:
                self.update("[dim]Select a tool call to view details[/dim]")
                return

            tc = self._tool_call

            # Format input JSON with indentation
            try:
                if isinstance(tc.input_json, str):
                    input_obj = json.loads(tc.input_json)
                else:
                    input_obj = tc.input_json
                input_formatted = json.dumps(input_obj, indent=2)
            except (json.JSONDecodeError, TypeError):
                input_formatted = str(tc.input_json)

            # Format result
            result_formatted = tc.result
            if result_formatted:
                # Try to format as JSON if possible
                try:
                    result_obj = json.loads(result_formatted)
                    result_formatted = json.dumps(result_obj, indent=2)
                except (json.JSONDecodeError, TypeError):
                    pass
                # Truncate very long results
                if len(result_formatted) > 2000:
                    result_formatted = result_formatted[:2000] + "\n... (truncated)"

            # Build status line
            if tc.success is None:
                status_line = "[yellow]Running...[/yellow]"
            elif tc.success:
                status_line = f"[green]Success[/green] ({tc.duration_ms}ms)"
            else:
                status_line = f"[red]Failed[/red] ({tc.duration_ms}ms)"

            # Escape brackets in JSON to prevent Rich markup interpretation
            # Use backslash escape: [ -> \[
            escaped_input = input_formatted.replace('[', '\\[') if input_formatted else '(no input)'
            escaped_result = result_formatted.replace('[', '\\[') if result_formatted else '(no output yet)'

            content = f"""[bold]Tool:[/bold] {tc.tool_name}
[bold]ID:[/bold] {tc.tool_id}
[bold]Description:[/bold] {tc.description}

[bold]Input:[/bold]
[dim]{escaped_input}[/dim]

[bold]Status:[/bold] {status_line}

[bold]Output:[/bold]
[dim]{escaped_result}[/dim]"""

            self.update(content)

    # =========================================================================
    # Main TUI App
    # =========================================================================
    class MonitorApp(App):
        """TUI for monitoring agent tool calls."""

        CSS = """
        Horizontal {
            height: 1fr;
        }
        #sidebar {
            width: 40;
            height: 100%;
            border-right: solid $primary;
        }
        #sidebar-title {
            height: 1;
            background: $primary;
            color: $text;
            text-align: center;
        }
        #detail-title {
            height: 1;
            background: $primary;
            color: $text;
            text-align: center;
        }
        #detail-scroll {
            height: 1fr;
            padding: 1;
        }
        #follow-indicator {
            height: 1;
            background: $success;
            color: $text;
            text-align: center;
        }
        #follow-indicator.paused {
            background: $warning;
        }
        ListView {
            height: 1fr;
        }
        ListItem {
            padding: 0 1;
        }
        ListItem:hover {
            background: $primary 30%;
        }
        ListView:focus ListItem.--highlight {
            background: $primary 50%;
        }
        """

        BINDINGS = [
            Binding("q", "quit", "Quit"),
            Binding("f", "toggle_follow", "Follow"),
            Binding("i", "copy_input", "Copy Input"),
            Binding("o", "copy_output", "Copy Output"),
            Binding("c", "copy_all", "Copy All"),
            Binding("up", "cursor_up", "Up", show=False),
            Binding("down", "cursor_down", "Down", show=False),
        ]

        follow_mode = reactive(True)

        def __init__(self, follow: bool):
            super().__init__()
            self.tool_calls: list[ToolCall] = []
            self.tool_calls_by_id: dict[str, ToolCall] = {}
            self.follow_mode = follow
            self._file_pos = 0
            self._current_tool_call: ToolCall = None

        def compose(self) -> ComposeResult:
            with Horizontal():
                with Vertical(id="sidebar"):
                    yield Static("Tool Calls", id="sidebar-title")
                    yield ListView(id="tool-list")
                with Vertical():
                    yield Static("Detail View", id="detail-title")
                    indicator_text = "Following" if self.follow_mode else "Paused"
                    yield Static(indicator_text, id="follow-indicator")
                    with VerticalScroll(id="detail-scroll"):
                        yield DetailView()
            yield Footer()

        def on_mount(self):
            """Load existing entries and start following if enabled."""
            self._load_existing_entries()
            if self.follow_mode:
                self._start_following()

        def _load_existing_entries(self):
            """Load existing tool call entries from the log file."""
            if not os.path.exists(MONITOR_LOG):
                return

            with open(MONITOR_LOG, "r") as f:
                for line in f:
                    line = line.strip()
                    if line:
                        self._process_line(line)
                self._file_pos = f.tell()

            # Update the list view
            self._refresh_list()

        def _process_line(self, line: str):
            """Process a single JSONL line."""
            try:
                data = json.loads(line)
            except json.JSONDecodeError:
                return

            event = data.get("event", "")

            if event == "tool_start":
                tool_id = data.get("tool_id", "")
                tc = ToolCall(
                    tool_id=tool_id,
                    tool_name=data.get("tool_name", ""),
                    description=data.get("description", ""),
                    input_json=data.get("input", {}),
                    timestamp=data.get("ts", "")
                )
                self.tool_calls.append(tc)
                self.tool_calls_by_id[tool_id] = tc

            elif event == "tool_end":
                tool_id = data.get("tool_id", "")
                tc = self.tool_calls_by_id.get(tool_id)
                if tc:
                    tc.success = data.get("success", False)
                    tc.duration_ms = data.get("duration_ms", 0)
                    tc.result = data.get("result", "")

        def _refresh_list(self):
            """Refresh the tool list view."""
            list_view = self.query_one("#tool-list", ListView)
            list_view.clear()

            # Show most recent at top (reverse chronological order)
            for i, tc in enumerate(reversed(self.tool_calls)):
                list_view.append(ToolListItem(tc, i))

            # If following, select the first item (most recent)
            if self.follow_mode and self.tool_calls:
                list_view.index = 0
                self._update_detail(self.tool_calls[-1])

        def _update_detail(self, tc: ToolCall):
            """Update the detail view with selected tool call."""
            self._current_tool_call = tc
            detail = self.query_one(DetailView)
            detail.set_tool_call(tc)

        def on_list_view_selected(self, event: ListView.Selected):
            """Handle tool selection in sidebar."""
            if event.item and isinstance(event.item, ToolListItem):
                self._update_detail(event.item.tool_call)

        def on_list_view_highlighted(self, event: ListView.Highlighted):
            """Handle tool highlight (cursor movement) in sidebar."""
            if event.item and isinstance(event.item, ToolListItem):
                self._update_detail(event.item.tool_call)

        @work(exclusive=True, thread=True)
        def _start_following(self):
            """Background worker to follow the log file."""
            if not os.path.exists(MONITOR_LOG):
                # Wait for file to exist
                while not os.path.exists(MONITOR_LOG) and self.follow_mode:
                    time.sleep(0.5)

            while self.follow_mode:
                try:
                    with open(MONITOR_LOG, "r") as f:
                        f.seek(self._file_pos)
                        while self.follow_mode:
                            line = f.readline()
                            if line:
                                line = line.strip()
                                if line:
                                    self._process_line(line)
                                    self.call_from_thread(self._refresh_list)
                                self._file_pos = f.tell()
                            else:
                                time.sleep(0.1)
                except FileNotFoundError:
                    time.sleep(0.5)

        def action_toggle_follow(self):
            """Toggle follow mode on/off."""
            self.follow_mode = not self.follow_mode
            indicator = self.query_one("#follow-indicator", Static)
            if self.follow_mode:
                indicator.update("Following")
                indicator.remove_class("paused")
                self._start_following()
            else:
                indicator.update("Paused")
                indicator.add_class("paused")

        def watch_follow_mode(self, value: bool):
            """React to follow_mode changes."""
            try:
                indicator = self.query_one("#follow-indicator", Static)
                if value:
                    indicator.update("Following")
                    indicator.remove_class("paused")
                else:
                    indicator.update("Paused")
                    indicator.add_class("paused")
            except Exception:
                pass  # Widget may not be mounted yet

        def action_copy_input(self):
            """Copy the current tool call's input to clipboard."""
            if self._current_tool_call:
                text = self._current_tool_call.get_input_text()
                if copy_to_clipboard(text):
                    self.notify("Input copied to clipboard")
                else:
                    self.notify("Failed to copy to clipboard", severity="error")
            else:
                self.notify("No tool call selected", severity="warning")

        def action_copy_output(self):
            """Copy the current tool call's output to clipboard."""
            if self._current_tool_call:
                text = self._current_tool_call.get_output_text()
                if text:
                    if copy_to_clipboard(text):
                        self.notify("Output copied to clipboard")
                    else:
                        self.notify("Failed to copy to clipboard", severity="error")
                else:
                    self.notify("No output available yet", severity="warning")
            else:
                self.notify("No tool call selected", severity="warning")

        def action_copy_all(self):
            """Copy both input and output to clipboard."""
            if self._current_tool_call:
                tc = self._current_tool_call
                text = f"Tool: {tc.tool_name}\nID: {tc.tool_id}\n\n"
                text += f"Input:\n{tc.get_input_text()}\n\n"
                text += f"Output:\n{tc.get_output_text() or '(no output)'}"
                if copy_to_clipboard(text):
                    self.notify("Copied to clipboard")
                else:
                    self.notify("Failed to copy to clipboard", severity="error")
            else:
                self.notify("No tool call selected", severity="warning")

    # Run the TUI app
    app = MonitorApp(follow=args.follow)
    app.run()


def _monitor_raw_json(args):
    """Raw JSON output mode for scripting."""
    if not os.path.exists(MONITOR_LOG):
        print(f"No monitor log found at {MONITOR_LOG}", file=sys.stderr)
        if args.follow:
            print("Waiting for log file...", file=sys.stderr)
            while not os.path.exists(MONITOR_LOG):
                time.sleep(0.5)
        else:
            return

    if args.follow:
        # Tail follow mode
        try:
            with open(MONITOR_LOG, "r") as f:
                f.seek(0, 2)  # Seek to end
                while True:
                    line = f.readline()
                    if line:
                        line = line.strip()
                        if line:
                            print(line)
                            sys.stdout.flush()
                    else:
                        time.sleep(0.1)
        except KeyboardInterrupt:
            pass
    else:
        # Show recent entries
        lines = []
        try:
            with open(MONITOR_LOG, "r") as f:
                for line in f:
                    line = line.strip()
                    if line:
                        lines.append(line)
        except FileNotFoundError:
            return

        # Show last 50 entries
        for line in lines[-50:]:
            print(line)


def main():
    zeo_version = _get_zeo_version()

    parser = argparse.ArgumentParser(
        prog="zeo",
        description="CLI tool for Zeo",
    )
    parser.add_argument(
        "-V", "--version",
        action="version",
        version=f"Zeo {zeo_version}",
    )
    subparsers = parser.add_subparsers(dest="command", help="Available commands")

    # shell subcommand
    subparsers.add_parser(
        "shell",
        help="Open an interactive Python shell with kipy imported",
    )

    # tool subcommand
    tool_parser = subparsers.add_parser(
        "tool",
        help="Execute agent tool calls (paste Python code from monitor logs)",
    )
    tool_parser.add_argument(
        "-v", "--verbose",
        action="store_true",
        help="Show full stack traces on errors",
    )

    # mcp subcommand
    subparsers.add_parser(
        "mcp",
        help="Run MCP server for Claude Code integration",
    )

    # monitor subcommand
    monitor_parser = subparsers.add_parser(
        "monitor",
        help="Watch agent shell calls and responses",
    )
    monitor_parser.add_argument(
        "-f", "--follow",
        action="store_true",
        help="Stream events in real-time (tail -f style)",
    )
    monitor_parser.add_argument(
        "--json",
        action="store_true",
        help="Output raw JSON lines",
    )

    args = parser.parse_args()

    if args.command is None:
        parser.print_help()
        sys.exit(1)

    if args.command == "shell":
        cmd_shell(args)
    elif args.command == "tool":
        cmd_tool(args)
    elif args.command == "mcp":
        cmd_mcp(args)
    elif args.command == "monitor":
        cmd_monitor(args)
    else:
        parser.print_help()
        sys.exit(1)


if __name__ == "__main__":
    main()
