+template<std::size_t N>
+inline std::ostream& operator<<( std::ostream& os, const wchar_t ( &aWs )[N] )
+{
+    os << wxString( aWs ).ToUTF8().data();
+    return os;
+}
+
+inline std::ostream& operator<<( std::ostream& os, const wchar_t* aWs )
+{
+    if( aWs )
+        os << wxString( aWs ).ToUTF8().data();
+
+    return os;
+}
