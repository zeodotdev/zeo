#!/bin/bash
# zeo - CLI tool for Zeo
#
# Must clear PYTHONHOME/PYTHONPATH set by the Zeo app bundle to avoid
# conflicts between the bundled Python framework and system Python.

unset PYTHONHOME
unset PYTHONPATH

# Create temp file for Python script, keeping stdin available for interactive use
_ZEO_SCRIPT=$(mktemp)
trap "rm -f '$_ZEO_SCRIPT'" EXIT

cat > "$_ZEO_SCRIPT" <<'PYTHON_EOF'
import argparse
import json
import os
import sys
import time


LOG_DIR = os.path.expanduser("~/Library/Logs/Zeo")
MONITOR_LOG = os.path.join(LOG_DIR, "agent-monitor.jsonl")

# Zeo version - read from cmake/ZeoVersion.cmake as single source of truth
ZEO_VERSION = "0.1.0"  # Fallback if cmake file not found

def _get_zeo_version():
    """Get Zeo version from cmake/ZeoVersion.cmake."""
    # Find the cmake file relative to this script
    script_dir = os.path.dirname(os.path.abspath(__file__))
    cmake_file = os.path.join(script_dir, "..", "cmake", "ZeoVersion.cmake")

    if os.path.exists(cmake_file):
        try:
            with open(cmake_file, "r") as f:
                for line in f:
                    if "ZEO_SEMANTIC_VERSION" in line and "set(" in line:
                        # Parse: set( ZEO_SEMANTIC_VERSION "0.1.0" )
                        import re
                        match = re.search(r'"([^"]+)"', line)
                        if match:
                            return match.group(1)
        except Exception:
            pass

    return ZEO_VERSION


def cmd_tool(args):
    """TUI for executing agent tool calls."""
    import traceback

    # ANSI colors
    CYAN = "\033[36m"
    GREEN = "\033[32m"
    YELLOW = "\033[33m"
    RED = "\033[31m"
    DIM = "\033[2m"
    BOLD = "\033[1m"
    RESET = "\033[0m"

    def clear_screen():
        print("\033[2J\033[H", end="")

    def print_header(sch_status, board_status):
        print(f"{BOLD}╔══════════════════════════════════════════════════════════════╗{RESET}")
        print(f"{BOLD}║  Zeo Tool Runner                                        [?]  ║{RESET}")
        print(f"{BOLD}╠══════════════════════════════════════════════════════════════╣{RESET}")
        print(f"{BOLD}║{RESET}  Schematic: {sch_status:<12}  PCB: {board_status:<12}              {BOLD}║{RESET}")
        print(f"{BOLD}╚══════════════════════════════════════════════════════════════╝{RESET}")

    def print_menu():
        print(f"\n{DIM}Commands:{RESET}")
        print(f"  {CYAN}[p]{RESET}aste  - Paste tool call JSON (end with blank line)")
        print(f"  {CYAN}[r]{RESET}un    - Execute the current buffer")
        print(f"  {CYAN}[c]{RESET}lear  - Clear the buffer")
        print(f"  {CYAN}[?]{RESET}      - List available tools")
        print(f"  {CYAN}[q]{RESET}uit   - Exit")

    def print_buffer(buffer_lines):
        print(f"\n{BOLD}─── Tool Call Buffer ───{RESET}")
        if buffer_lines:
            for i, line in enumerate(buffer_lines[:20]):  # Show first 20 lines
                print(f"{DIM}{i+1:3}│{RESET} {line}")
            if len(buffer_lines) > 20:
                print(f"{DIM}... ({len(buffer_lines) - 20} more lines){RESET}")
        else:
            print(f"{DIM}(empty - use 'p' to paste){RESET}")
        print(f"{BOLD}────────────────────────{RESET}")

    def print_tools():
        """Print available agent tools."""
        tools = [
            ("sch_get_summary", "Get high-level overview of schematic"),
            ("sch_inspect", "Inspect specific section (symbols, wires, etc.)"),
            ("sch_add", "Add elements to schematic"),
            ("sch_update", "Update schematic elements"),
            ("sch_delete", "Delete schematic elements"),
            ("sch_switch_sheet", "Switch to a different sheet"),
            ("sch_add_sheet", "Add a new hierarchical sheet"),
            ("sch_connect_net", "Auto-route wires between pins"),
            ("sch_run_erc", "Run electrical rules check"),
            ("sch_setup", "Get/set schematic settings"),
            ("pcb_get_summary", "Get high-level overview of PCB"),
            ("pcb_inspect", "Inspect specific section of PCB"),
            ("pcb_add", "Add elements to PCB"),
            ("pcb_update", "Update PCB elements"),
            ("pcb_delete", "Delete PCB elements"),
            ("run_terminal", "Execute bash/shell commands"),
            ("check_status", "Get project and editor status"),
        ]

        print(f"\n{BOLD}─── Available Tools ───{RESET}")
        for name, desc in tools:
            print(f"  {CYAN}{name:<22}{RESET} {desc}")
        print(f"{BOLD}───────────────────────{RESET}")
        print(f"\n{DIM}Tool call format:{RESET}")
        print(f'  {{"name": "tool_name", "input": {{...}}}}')

    def execute_tool(buffer_lines, namespace):
        """Execute the tool call in the buffer."""
        if not buffer_lines:
            print(f"{YELLOW}Buffer is empty. Use 'p' to paste a tool call.{RESET}")
            return

        buffer_text = "\n".join(buffer_lines)

        # Try to parse as JSON tool call
        try:
            tool_call = json.loads(buffer_text)
            if isinstance(tool_call, dict) and "name" in tool_call:
                # It's a tool call JSON - generate Python code
                tool_name = tool_call.get("name", "")
                tool_input = tool_call.get("input", {})

                print(f"\n{CYAN}Executing tool: {tool_name}{RESET}")
                print(f"{DIM}Input: {json.dumps(tool_input, indent=2)}{RESET}")

                # For now, we can't directly execute tool calls without the C++ handler
                # So we'll show what the user would need to do in Python
                print(f"\n{YELLOW}Note: Direct tool execution not yet implemented.{RESET}")
                print(f"{DIM}Use 'zeo shell' to run Python code directly, e.g.:{RESET}")
                if tool_name.startswith("sch_"):
                    print(f"  sch.get_symbols()  # for sch_inspect")
                elif tool_name.startswith("pcb_"):
                    print(f"  board.get_footprints()  # for pcb_inspect")
                return
        except json.JSONDecodeError:
            pass

        # Execute as Python code
        print(f"\n{CYAN}Executing Python code...{RESET}")
        try:
            # Try as expression first
            result = eval(buffer_text, namespace)
            if result is not None:
                print(f"\n{GREEN}Result:{RESET}")
                try:
                    print(json.dumps(result, indent=2, default=str))
                except (TypeError, ValueError):
                    print(result)
        except SyntaxError:
            # Execute as statements
            exec(buffer_text, namespace)
            print(f"{GREEN}Executed successfully.{RESET}")

    # Try to import kipy
    try:
        from kipy import KiCad
    except ImportError as e:
        print(f"Error: Could not import kipy: {e}")
        print("\nMake sure kipy is installed with:")
        print("  pip install -e /path/to/zeo-python")
        sys.exit(1)

    # Connect to Zeo
    zeo_version = _get_zeo_version()
    print(f"Connecting to Zeo {zeo_version}...")
    try:
        kicad = KiCad()
        kicad_version = kicad.get_version()
        print(f"Connected (KiCad {kicad_version})")
    except Exception as e:
        print(f"Error: Could not connect to Zeo: {e}")
        print("Make sure Zeo is running with a project open.")
        sys.exit(1)

    # Get schematic and board
    sch = None
    board = None
    sch_status = f"{RED}not open{RESET}"
    board_status = f"{RED}not open{RESET}"

    try:
        sch = kicad.get_schematic()
        sch_status = f"{GREEN}connected{RESET}"
    except Exception:
        pass

    try:
        board = kicad.get_board()
        board_status = f"{GREEN}connected{RESET}"
    except Exception:
        pass

    # Set up namespace for exec
    namespace = {
        'kicad': kicad,
        'sch': sch,
        'board': board,
        'json': json,
    }

    buffer_lines = []

    # Main loop
    clear_screen()
    while True:
        try:
            print_header(sch_status, board_status)
            print_buffer(buffer_lines)
            print_menu()

            cmd = input(f"\n{BOLD}>{RESET} ").strip().lower()

            if cmd in ('q', 'quit', 'exit'):
                break
            elif cmd in ('?', 'tools', 'help'):
                clear_screen()
                print_tools()
                input(f"\n{DIM}Press Enter to continue...{RESET}")
                clear_screen()
            elif cmd in ('p', 'paste'):
                clear_screen()
                print(f"{CYAN}Paste your tool call JSON or Python code.{RESET}")
                print(f"{DIM}End with a blank line.{RESET}\n")
                buffer_lines = []
                while True:
                    try:
                        line = input()
                        if line == "":
                            break
                        buffer_lines.append(line)
                    except EOFError:
                        break
                clear_screen()
                if buffer_lines:
                    print(f"{GREEN}Pasted {len(buffer_lines)} lines.{RESET}\n")
            elif cmd in ('r', 'run'):
                try:
                    execute_tool(buffer_lines, namespace)
                except Exception as e:
                    print(f"{RED}Error:{RESET} {e}")
                    if args.verbose:
                        traceback.print_exc()
                input(f"\n{DIM}Press Enter to continue...{RESET}")
                clear_screen()
            elif cmd in ('c', 'clear'):
                buffer_lines = []
                clear_screen()
                print(f"{GREEN}Buffer cleared.{RESET}\n")
            else:
                clear_screen()
                print(f"{YELLOW}Unknown command: {cmd}{RESET}\n")

        except KeyboardInterrupt:
            print(f"\n{DIM}(Use 'q' to quit){RESET}")
            continue

    print(f"\n{DIM}Goodbye!{RESET}")


def cmd_shell(args):
    """Open an interactive Python shell with kipy imported."""
    import code
    import readline  # noqa: F401 - enables arrow keys, history
    import rlcompleter  # noqa: F401 - enables tab completion

    # Try to import kipy
    try:
        from kipy import KiCad
    except ImportError as e:
        print(f"Error: Could not import kipy: {e}")
        print("\nMake sure kipy is installed. You can install it with:")
        print("  pip install -e /path/to/zeo-python")
        sys.exit(1)

    # Connect to Zeo
    zeo_version = _get_zeo_version()
    print(f"Connecting to Zeo {zeo_version}...")
    try:
        kicad = KiCad()
        kicad_version = kicad.get_version()
        print(f"Connected (KiCad {kicad_version})")
    except Exception as e:
        print(f"Warning: Could not connect to Zeo: {e}")
        print("You can try connecting manually with: kicad = KiCad()")
        kicad = None

    # Set up the namespace with useful imports and objects
    namespace = {
        'KiCad': KiCad,
        'kicad': kicad,
    }

    # Try to get schematic and board if connected
    sch = None
    board = None
    if kicad:
        try:
            sch = kicad.get_schematic()
            namespace['sch'] = sch
            print("Schematic available as 'sch'")
        except Exception:
            pass

        try:
            board = kicad.get_board()
            namespace['board'] = board
            print("Board available as 'board'")
        except Exception:
            pass

        if not sch and not board:
            print("\n\033[33mWarning: No editors connected. Open the schematic or PCB editor in Zeo first.\033[0m")

    # Enable tab completion
    readline.set_completer(rlcompleter.Completer(namespace).complete)
    readline.parse_and_bind("tab: complete")

    # Print help
    print("\n" + "=" * 50)
    print("Zeo Shell - Interactive Python with kipy")
    print("=" * 50)
    print("\nAvailable objects:")
    print("  kicad   - KiCad connection")
    if sch:
        print("  sch     - Current schematic")
    if board:
        print("  board   - Current board")
    print("\nExample commands:")
    print("  kicad.ping()")
    print("  sch.get_symbols()")
    print("  board.get_footprints()")
    print("\nType 'exit()' or Ctrl-D to quit.")
    print()

    # Start interactive shell
    code.interact(local=namespace, banner="", exitmsg="")


def cmd_monitor(args):
    """Watch agent tool calls and responses with TUI."""
    # Raw JSON mode - use simple output
    if args.json:
        _monitor_raw_json(args)
        return

    # Check for textual library
    try:
        from textual.app import App, ComposeResult
        from textual.containers import Horizontal, Vertical, VerticalScroll
        from textual.widgets import Static, ListView, ListItem, Label, Footer
        from textual.reactive import reactive
        from textual.binding import Binding
        from textual import work
        from textual.message import Message
    except ImportError:
        print("Error: textual library required for TUI mode.")
        print("Install with: pip install textual")
        print("\nFalling back to raw JSON mode...")
        args.json = True
        _monitor_raw_json(args)
        return

    # =========================================================================
    # Tool Call data structure
    # =========================================================================
    class ToolCall:
        """Represents a tool call with start/end data."""
        def __init__(self, tool_id, tool_name, description, input_json, timestamp):
            self.tool_id = tool_id
            self.tool_name = tool_name
            self.description = description
            self.input_json = input_json
            self.timestamp = timestamp
            self.success = None  # None = running, True = success, False = failed
            self.duration_ms = 0
            self.result = ""

        def time_str(self):
            """Get HH:MM:SS from timestamp."""
            if "T" in self.timestamp:
                return self.timestamp.split("T")[1].split(".")[0]
            return self.timestamp[:8]

        def status_str(self):
            """Get status string for display."""
            if self.success is None:
                return "[yellow]RUN[/yellow]"
            elif self.success:
                return "[green]OK[/green]"
            else:
                return "[red]FAIL[/red]"

    # =========================================================================
    # Custom widgets
    # =========================================================================
    class ToolListItem(ListItem):
        """A single tool call in the sidebar list."""
        def __init__(self, tool_call: ToolCall, index: int):
            super().__init__()
            self.tool_call = tool_call
            self.index = index

        def compose(self) -> ComposeResult:
            tc = self.tool_call
            # Truncate description for sidebar
            desc = tc.description[:35] + "..." if len(tc.description) > 38 else tc.description
            yield Static(
                f"{tc.time_str()} {tc.status_str()}\n [dim]{desc}[/dim]",
                markup=True
            )

    class DetailView(Static):
        """Right panel showing selected tool call details."""
        def __init__(self):
            super().__init__("")
            self._tool_call = None

        def set_tool_call(self, tc: ToolCall):
            self._tool_call = tc
            self._update_content()

        def _update_content(self):
            if self._tool_call is None:
                self.update("[dim]Select a tool call to view details[/dim]")
                return

            tc = self._tool_call

            # Format input JSON with indentation
            try:
                if isinstance(tc.input_json, str):
                    input_obj = json.loads(tc.input_json)
                else:
                    input_obj = tc.input_json
                input_formatted = json.dumps(input_obj, indent=2)
            except (json.JSONDecodeError, TypeError):
                input_formatted = str(tc.input_json)

            # Format result
            result_formatted = tc.result
            if result_formatted:
                # Try to format as JSON if possible
                try:
                    result_obj = json.loads(result_formatted)
                    result_formatted = json.dumps(result_obj, indent=2)
                except (json.JSONDecodeError, TypeError):
                    pass
                # Truncate very long results
                if len(result_formatted) > 2000:
                    result_formatted = result_formatted[:2000] + "\n... (truncated)"

            # Build status line
            if tc.success is None:
                status_line = "[yellow]Running...[/yellow]"
            elif tc.success:
                status_line = f"[green]Success[/green] ({tc.duration_ms}ms)"
            else:
                status_line = f"[red]Failed[/red] ({tc.duration_ms}ms)"

            content = f"""[bold]Tool:[/bold] {tc.tool_name}
[bold]ID:[/bold] {tc.tool_id}
[bold]Description:[/bold] {tc.description}

[bold]Input:[/bold]
[dim]{input_formatted}[/dim]

[bold]Status:[/bold] {status_line}

[bold]Output:[/bold]
[dim]{result_formatted if result_formatted else '(no output yet)'}[/dim]"""

            self.update(content)

    # =========================================================================
    # Main TUI App
    # =========================================================================
    class MonitorApp(App):
        """TUI for monitoring agent tool calls."""

        CSS = """
        Horizontal {
            height: 1fr;
        }
        #sidebar {
            width: 40;
            height: 100%;
            border-right: solid $primary;
        }
        #sidebar-title {
            height: 1;
            background: $primary;
            color: $text;
            text-align: center;
        }
        #detail-title {
            height: 1;
            background: $primary;
            color: $text;
            text-align: center;
        }
        #detail-scroll {
            height: 1fr;
            padding: 1;
        }
        #follow-indicator {
            height: 1;
            background: $success;
            color: $text;
            text-align: center;
        }
        #follow-indicator.paused {
            background: $warning;
        }
        ListView {
            height: 1fr;
        }
        ListItem {
            padding: 0 1;
        }
        ListItem:hover {
            background: $primary 30%;
        }
        ListView:focus ListItem.--highlight {
            background: $primary 50%;
        }
        """

        BINDINGS = [
            Binding("q", "quit", "Quit"),
            Binding("f", "toggle_follow", "Follow"),
            Binding("up", "cursor_up", "Up", show=False),
            Binding("down", "cursor_down", "Down", show=False),
        ]

        follow_mode = reactive(True)

        def __init__(self, follow: bool):
            super().__init__()
            self.tool_calls: list[ToolCall] = []
            self.tool_calls_by_id: dict[str, ToolCall] = {}
            self.follow_mode = follow
            self._file_pos = 0

        def compose(self) -> ComposeResult:
            with Horizontal():
                with Vertical(id="sidebar"):
                    yield Static("Tool Calls", id="sidebar-title")
                    yield ListView(id="tool-list")
                with Vertical():
                    yield Static("Detail View", id="detail-title")
                    indicator_text = "Following" if self.follow_mode else "Paused"
                    yield Static(indicator_text, id="follow-indicator")
                    with VerticalScroll(id="detail-scroll"):
                        yield DetailView()
            yield Footer()

        def on_mount(self):
            """Load existing entries and start following if enabled."""
            self._load_existing_entries()
            if self.follow_mode:
                self._start_following()

        def _load_existing_entries(self):
            """Load existing tool call entries from the log file."""
            if not os.path.exists(MONITOR_LOG):
                return

            with open(MONITOR_LOG, "r") as f:
                for line in f:
                    line = line.strip()
                    if line:
                        self._process_line(line)
                self._file_pos = f.tell()

            # Update the list view
            self._refresh_list()

        def _process_line(self, line: str):
            """Process a single JSONL line."""
            try:
                data = json.loads(line)
            except json.JSONDecodeError:
                return

            event = data.get("event", "")

            if event == "tool_start":
                tool_id = data.get("tool_id", "")
                tc = ToolCall(
                    tool_id=tool_id,
                    tool_name=data.get("tool_name", ""),
                    description=data.get("description", ""),
                    input_json=data.get("input", {}),
                    timestamp=data.get("ts", "")
                )
                self.tool_calls.append(tc)
                self.tool_calls_by_id[tool_id] = tc

            elif event == "tool_end":
                tool_id = data.get("tool_id", "")
                tc = self.tool_calls_by_id.get(tool_id)
                if tc:
                    tc.success = data.get("success", False)
                    tc.duration_ms = data.get("duration_ms", 0)
                    tc.result = data.get("result", "")

        def _refresh_list(self):
            """Refresh the tool list view."""
            list_view = self.query_one("#tool-list", ListView)
            list_view.clear()

            # Show most recent at bottom (chronological order)
            for i, tc in enumerate(self.tool_calls):
                list_view.append(ToolListItem(tc, i))

            # If following, scroll to bottom and select last item
            if self.follow_mode and self.tool_calls:
                list_view.index = len(self.tool_calls) - 1
                self._update_detail(self.tool_calls[-1])

        def _update_detail(self, tc: ToolCall):
            """Update the detail view with selected tool call."""
            detail = self.query_one(DetailView)
            detail.set_tool_call(tc)

        def on_list_view_selected(self, event: ListView.Selected):
            """Handle tool selection in sidebar."""
            if event.item and isinstance(event.item, ToolListItem):
                self._update_detail(event.item.tool_call)

        def on_list_view_highlighted(self, event: ListView.Highlighted):
            """Handle tool highlight (cursor movement) in sidebar."""
            if event.item and isinstance(event.item, ToolListItem):
                self._update_detail(event.item.tool_call)

        @work(exclusive=True, thread=True)
        def _start_following(self):
            """Background worker to follow the log file."""
            if not os.path.exists(MONITOR_LOG):
                # Wait for file to exist
                while not os.path.exists(MONITOR_LOG) and self.follow_mode:
                    time.sleep(0.5)

            while self.follow_mode:
                try:
                    with open(MONITOR_LOG, "r") as f:
                        f.seek(self._file_pos)
                        while self.follow_mode:
                            line = f.readline()
                            if line:
                                line = line.strip()
                                if line:
                                    self._process_line(line)
                                    self.call_from_thread(self._refresh_list)
                                self._file_pos = f.tell()
                            else:
                                time.sleep(0.1)
                except FileNotFoundError:
                    time.sleep(0.5)

        def action_toggle_follow(self):
            """Toggle follow mode on/off."""
            self.follow_mode = not self.follow_mode
            indicator = self.query_one("#follow-indicator", Static)
            if self.follow_mode:
                indicator.update("Following")
                indicator.remove_class("paused")
                self._start_following()
            else:
                indicator.update("Paused")
                indicator.add_class("paused")

        def watch_follow_mode(self, value: bool):
            """React to follow_mode changes."""
            try:
                indicator = self.query_one("#follow-indicator", Static)
                if value:
                    indicator.update("Following")
                    indicator.remove_class("paused")
                else:
                    indicator.update("Paused")
                    indicator.add_class("paused")
            except Exception:
                pass  # Widget may not be mounted yet

    # Run the TUI app
    app = MonitorApp(follow=args.follow)
    app.run()


def _monitor_raw_json(args):
    """Raw JSON output mode for scripting."""
    if not os.path.exists(MONITOR_LOG):
        print(f"No monitor log found at {MONITOR_LOG}", file=sys.stderr)
        if args.follow:
            print("Waiting for log file...", file=sys.stderr)
            while not os.path.exists(MONITOR_LOG):
                time.sleep(0.5)
        else:
            return

    if args.follow:
        # Tail follow mode
        try:
            with open(MONITOR_LOG, "r") as f:
                f.seek(0, 2)  # Seek to end
                while True:
                    line = f.readline()
                    if line:
                        line = line.strip()
                        if line:
                            print(line)
                            sys.stdout.flush()
                    else:
                        time.sleep(0.1)
        except KeyboardInterrupt:
            pass
    else:
        # Show recent entries
        lines = []
        try:
            with open(MONITOR_LOG, "r") as f:
                for line in f:
                    line = line.strip()
                    if line:
                        lines.append(line)
        except FileNotFoundError:
            return

        # Show last 50 entries
        for line in lines[-50:]:
            print(line)


def main():
    zeo_version = _get_zeo_version()

    parser = argparse.ArgumentParser(
        prog="zeo",
        description="CLI tool for Zeo",
    )
    parser.add_argument(
        "-V", "--version",
        action="version",
        version=f"Zeo {zeo_version}",
    )
    subparsers = parser.add_subparsers(dest="command", help="Available commands")

    # shell subcommand
    subparsers.add_parser(
        "shell",
        help="Open an interactive Python shell with kipy imported",
    )

    # tool subcommand
    tool_parser = subparsers.add_parser(
        "tool",
        help="Execute agent tool calls (paste Python code from monitor logs)",
    )
    tool_parser.add_argument(
        "-v", "--verbose",
        action="store_true",
        help="Show full stack traces on errors",
    )

    # monitor subcommand
    monitor_parser = subparsers.add_parser(
        "monitor",
