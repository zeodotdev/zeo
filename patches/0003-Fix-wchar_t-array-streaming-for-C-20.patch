+// Forward declarations for wchar_t streaming operators.
+// Must be visible before boost includes because lazy_ostream_impl uses operator<<
+// in a dependent context. Two-phase lookup only finds global-namespace overloads
+// via ordinary unqualified lookup at the template definition point; wchar_t is a
+// fundamental type with no associated namespace so ADL alone cannot find them.
+template<std::size_t N>
+std::ostream& operator<<( std::ostream& os, const wchar_t ( &aWs )[N] );
+std::ostream& operator<<( std::ostream& os, const wchar_t* aWs );
+
